/* ============== FRIENDS / LINK PAGE ============== */
.friends-page {
  padding-bottom: 32px;
}

.friends-subtitle {
  margin: 8px 0 0;
  color: var(--muted);
  font-size: 13px;
}

.friends-page .friends-intro {
  margin-top: 32px;
  padding: 32px 0 4px;
  font-size: 14px;
  border-top: 1px dashed var(--line);
}

.friends-page .friends-intro > :first-child { margin-top: 0; }
.friends-intro > :last-child { margin-bottom: 0; }

.friends-group {
  margin-top: 28px;
}

.friends-group__head {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8px 14px;
  margin-bottom: 16px;
}

.friends-group__head h2 {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin: 0;
  font-size: 18px;
  font-weight: 700;
}

.friends-group__desc {
  color: var(--muted);
  font-size: 12px;
}

.friends-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 14px;
  margin: 0;
  padding: 0;
  list-style: none;
}

.friend-card {
  position: relative;
}

.friend-card__rss {
  position: absolute;
  top: 8px;
  right: 8px;
  z-index: 2;
  display: inline-grid;
  place-items: center;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  color: var(--muted);
  background: transparent;
  transition: color 0.25s ease, background 0.25s ease, transform 0.25s ease;
}

.friend-card__rss .lucide {
  width: 13px;
  height: 13px;
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* Signal-wave ring that pulses out when the card is hovered */
.friend-card__rss::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 1.5px solid currentColor;
  opacity: 0;
  pointer-events: none;
}

.friend-card:hover .friend-card__rss {
  color: var(--color-accent-strong);
  background: var(--color-accent-soft);
}

.friend-card:hover .friend-card__rss .lucide {
  animation: flatpaper-rss-wiggle 0.7s ease;
}

.friend-card:hover .friend-card__rss::before {
  animation: flatpaper-rss-pulse 1.1s ease-out;
}

.friend-card__rss:hover {
  transform: scale(1.1);
}

@keyframes flatpaper-rss-wiggle {
  0%   { transform: rotate(0)    scale(1); }
  25%  { transform: rotate(-8deg) scale(1.08); }
  50%  { transform: rotate(6deg)  scale(1.12); }
  75%  { transform: rotate(-3deg) scale(1.06); }
  100% { transform: rotate(0)    scale(1); }
}

@keyframes flatpaper-rss-pulse {
  0%   { opacity: 0.45; transform: scale(1); }
  100% { opacity: 0;    transform: scale(1.9); }
}

.dark-mode .friend-card:hover .friend-card__rss {
  color: var(--color-accent-muted);
  background: var(--color-accent-soft);
}

.friend-card__link {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  border: 1px dashed var(--dash);
  border-radius: 12px;
  background: var(--paper);
  color: var(--ink);
  text-decoration: none;
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
}

.friend-card__link:hover {
  transform: translateY(-3px);
  border-color: var(--color-accent);
  box-shadow: var(--small-shadow);
}

.friend-card__avatar {
  flex-shrink: 0;
  display: inline-grid;
  place-items: center;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  object-fit: cover;
  background: var(--color-accent-soft);
  color: var(--color-accent-strong);
  font-weight: 700;
  font-size: 18px;
}

img.friend-card__avatar {
  background: var(--paper);
}

.dark-mode .friend-card__avatar--text {
  color: var(--color-accent-muted);
}

.friend-card__body {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.friend-card__name {
  font-size: 14px;
  font-weight: 700;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.friend-card__link:hover .friend-card__name {
  color: var(--color-accent-strong);
}

.dark-mode .friend-card__link:hover .friend-card__name {
  color: var(--color-accent-muted);
}

.friend-card__desc {
  color: var(--muted);
  font-size: 12px;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* Shown when a friends group has no entries. */
.friends-empty {
  margin: 24px 0 8px;
  text-align: center;
  color: var(--muted);
  font-size: 13px;
}

/* --- Paper Style Friend Cards --- */
.friend-card--paper {
  z-index: 1;
}

.friend-card--paper:hover {
  z-index: 10;
}

.friend-card--paper .friend-card__link {
  border: 2px dashed var(--dash);
  border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
  background: var(--paper-warm);
  box-shadow: var(--soft-shadow);
  transform-origin: center top;
}

.friend-card--paper:nth-child(even) .friend-card__link {
  transform: rotate(1.5deg);
}

.friend-card--paper:nth-child(odd) .friend-card__link {
  transform: rotate(-1.5deg);
}

.friend-card--paper .friend-card__link:hover {
  transform: translateY(-4px) scale(1.02) rotate(0deg);
  border-color: var(--color-accent);
  box-shadow: 0 10px 22px rgba(82, 64, 38, 0.15);
}

.dark-mode .friend-card--paper .friend-card__link:hover {
  box-shadow: 0 10px 22px rgba(0, 0, 0, 0.4);
}

/* Scrapbook tape for paper cards */
.friend-card--paper::after {
  content: "";
  position: absolute;
  top: -10px;
  left: 50%;
  transform: translateX(-50%) rotate(-2deg);
  width: 66px;
  height: 20px;
  background-color: var(--tape-yellow);
  background-image: var(--tape-stripes);
  z-index: 12;
  pointer-events: none;
}

.friend-card--paper:nth-child(2n)::after {
  background-color: var(--tape-blue);
  transform: translateX(-50%) rotate(3deg);
}

.friend-card--paper:nth-child(3n)::after {
  background-color: var(--tape-pink);
  transform: translateX(-50%) rotate(-1deg);
}

.friend-card--paper:nth-child(4n)::after {
  background-color: var(--tape-green);
  transform: translateX(-50%) rotate(2deg);
}

.tape-disabled .friend-card--paper::after {
  display: none;
}
